  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "1. \u4E0D\u540C\u7F51\u683C\u56FE\u5171\u4EAB\u6570\u636E\uFF0C\u4F46\u4F7F\u7528\u7684\u7B97\u6CD5\u5F7C\u6B64\u72EC\u7ACB\n2.
    \u6309\u4E0BESC\u6253\u5F00\u6682\u505C\u83DC\u5355\n3. \u4F7F\u7528\u9F20\u6807\u53F3\u952E\u62D6\u52A8\u753B\u9762\u79FB\u52A8\uFF0C\u6EDA\u8F6E\u7F29\u653E\u753B\u9762\u5927\u5C0F\n4.
    \u4F7F\u7528\u9F20\u6807\u5DE6\u952E\u53EF\u9009\u4E2D\u7F51\u683C\u56FE\uFF1A\n   
    - \u9009\u4E2D\u540E\u53EF\u4F7F\u7528\u6B63\u4E0A\u65B9\u7684\u63A7\u5236\u9762\u677F\u4FEE\u6539\u8BE5\u56FE\u7684\u5BFB\u8DEF\u65B9\u5F0F\u6216\u5220\u9664\u8BE5\u56FE\n   
    - \u957F\u6309\u5DE6\u952E\u62D6\u52A8\u5F53\u524D\u9009\u4E2D\u7684\u7F51\u683C\u56FE\n5.
    \u5DE6\u4FA7\u4E3A\u5168\u5C40\u63A7\u5236\u9762\u677F\u529F\u80FD\uFF1A\n   
    - \u8F93\u5165\u7F51\u683C\u5C3A\u5BF8\u5E76\u70B9\u51FB\u5E94\u7528\u4EE5\u8BBE\u7F6E\u6240\u6709\u56FE\u7684\u884C\u5217\u6570\u91CF\n   
    - \u8BBE\u7F6E\u6240\u6709\u8FB9\u6846\u7684\u7C97\u7EC6\uFF0C\u8FD0\u884C\u65F6\u53EF\u4EE5\u52A8\u6001\u8C03\u6574\n   
    - \u8BBE\u7F6E\u5355\u6B21\u64CD\u4F5C\u7684\u65F6\u95F4\u95F4\u9694\uFF0C\u8FD0\u884C\u65F6\u53EF\u4EE5\u52A8\u6001\u8C03\u6574\n   
    - \u5168\u90E8\u5F00\u59CB\u6216\u6682\u505C\n    - \u70B9\u51FB\u95EE\u53F7\u6309\u94AE\u663E\u793A\u672C\u8BF4\u660E\n   
    - \u7F16\u8F91\u6A21\u5F0F\uFF1A\n        - \u70B9\u51FB\u8FDB\u5165\u4E09\u79CD\u7F16\u8F91\u6A21\u5F0F\u4E2D\u7684\u4E00\u79CD\uFF0C\u518D\u6B21\u70B9\u51FB\u5219\u9000\u51FA\n       
    - \u540C\u4E00\u6A21\u5F0F\u4E0B\u91CD\u590D\u4FEE\u6539\u540C\u4E00\u70B9\u5219\u8BE5\u70B9\u6062\u590D\u9ED8\u8BA4\u72B6\u6001\n       
    - \u9009\u62E9\u201C\u653E\u7F6E\u969C\u788D\u201D\uFF0C\u53EF\u7528\u9F20\u6807\u5DE6\u952E\u5728\u56FE\u4E0A\u653E\u7F6E\u9ED1\u8272\u969C\u788D\u70B9\n       
    - \u9009\u62E9\u201C\u8BBE\u7F6E\u8D77\u70B9\u201D\uFF0C\u53EF\u7528\u9F20\u6807\u5DE6\u952E\u5728\u56FE\u4E0A\u8BBE\u7F6E\u84DD\u8272\u8D77\u70B9\u3002\u8D77\u70B9\u53EA\u6709\u4E00\u4E2A\n       
    - \u9009\u62E9\u201C\u8BBE\u7F6E\u7EC8\u70B9\u201D\uFF0C\u53EF\u7528\u9F20\u6807\u5DE6\u952E\u5728\u56FE\u4E0A\u8BBE\u7F6E\u7EA2\u8272\u7EC8\u70B9\u3002\u7EC8\u70B9\u53EA\u6709\u4E00\u4E2A"
