  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "1. \u4E0D\u540C\u7F51\u683C\u56FE\u5171\u4EAB\u6570\u636E\uFF0C\u4F46\u4F7F\u7528\u7684\u7B97\u6CD5\u5F7C\u6B64\u72EC\u7ACB\n2.
    \u6309\u4E0BESC\u6253\u5F00\u6682\u505C\u83DC\u5355\n3. \u4F7F\u7528\u9F20\u6807\u53F3\u952E\u62D6\u52A8\u753B\u9762\u79FB\u52A8\uFF0C\u6EDA\u8F6E\u7F29\u653E\u753B\u9762\u5927\u5C0F\n4.
    \u4F7F\u7528\u9F20\u6807\u5DE6\u952E\u53EF\u9009\u4E2D\u6811\uFF1A\n    - \u9009\u4E2D\u540E\u53EF\u4F7F\u7528\u53F3\u4E0A\u89D2\u7684\u63A7\u5236\u9762\u677F\u4FEE\u6539\u8BE5\u6811\u7684\u5B9E\u73B0\u65B9\u5F0F\u6216\u5220\u9664\u8BE5\u6811\n   
    - \u957F\u6309\u5DE6\u952E\u62D6\u52A8\u5F53\u524D\u9009\u4E2D\u7684\u6811\n   
    - \u5355\u6811\u64CD\u4F5C\u4EC5\u5BF9\u9009\u4E2D\u6811\u751F\u6548\uFF1A\n       
    - \u8BBE\u7F6E\u76EE\u6807\u503C\u4EE5\u67E5\u627E\u6216\u5220\u9664\u8BE5\u503C\n       
    - \u8BBE\u7F6E\u65B0\u503C\u4EE5\u5C06\u76EE\u6807\u503C\u6362\u4E3A\u65B0\u503C\n       
    - \u70B9\u51FB\u201C\u63D2\u5165\u5F53\u524D\u6811\u201D\uFF0C\u4EE5\u5C06\u5168\u5C40\u63A7\u5236\u9762\u677F\u4E2D\u63D2\u5165\u5217\u8868\u7684\u5143\u7D20\u4F9D\u6B21\u63D2\u5165\n5.
    \u5DE6\u4FA7\u4E3A\u5168\u5C40\u63A7\u5236\u9762\u677F\u529F\u80FD\uFF1A\n   
    - \u8BBE\u7F6E\u5355\u6B21\u64CD\u4F5C\u7684\u65F6\u95F4\u95F4\u9694\uFF0C\u8FD0\u884C\u65F6\u53EF\u4EE5\u52A8\u6001\u8C03\u6574\n   
    - \u8BBE\u7F6E\u8981\u65B0\u5EFA\u7684\u6811\u7684\u6A21\u5F0F\uFF0C\u70B9\u51FB\u201C\u65B0\u5EFA\u6811\u201D\u4EE5\u751F\u6210\u8BE5\u6811\n   
    - \u5168\u90E8\u5F00\u59CB\u6216\u6682\u505C\n    - \u70B9\u51FB\u95EE\u53F7\u6309\u94AE\u663E\u793A\u672C\u8BF4\u660E\n   
    - \u5168\u5C40\u64CD\u4F5C\u5BF9\u6240\u6709\u6811\u751F\u6548\uFF1A\n       
    - \u8BBE\u7F6E\u76EE\u6807\u503C\u4EE5\u67E5\u627E\u6216\u5220\u9664\u8BE5\u503C\n       
    - \u8BBE\u7F6E\u65B0\u503C\u4EE5\u5C06\u76EE\u6807\u503C\u6362\u4E3A\u65B0\u503C\n   
    - \u63D2\u5165\u5217\u8868\uFF1A\n        - \u70B9\u51FB\u201C\u63D2\u5165\u6240\u6709\u6811\u201D\uFF0C\u4EE5\u5C06\u5168\u5C40\u63A7\u5236\u9762\u677F\u4E2D\u63D2\u5165\u5217\u8868\u7684\u5143\u7D20\u4F9D\u6B21\u63D2\u5165\n       
    - \u70B9\u51FB\u201C\u6DFB\u52A0\u5143\u7D20\u201D\u6216\u201C\u5220\u9664\u5143\u7D20\u201D\uFF0C\u5728\u5217\u8868\u4E2D\u6DFB\u52A0\u6216\u5220\u9664\u672B\u5C3E\u5143\u7D20\u3002"
